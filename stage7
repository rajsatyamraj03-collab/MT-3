<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Project Report</title>

  <!-- Markdown Parser (ready to use later) -->
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

  <!-- Mermaid -->
  <script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>

  <style>
    :root {
      --bg: #f6f8fa;
      --card: #ffffff;
      --text: #24292f;
      --muted: #57606a;
      --border: #d0d7de;
      --accent: #0969da;
    }

    body {
      margin: 0;
      background: var(--bg);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      color: var(--text);
    }

    .page {
      display: flex;
      justify-content: center;
      padding: 40px 16px;
    }

    .report {
      width: 100%;
      max-width: 900px;
      background: var(--card);
      padding: 40px;
      border-radius: 12px;
      border: 1px solid var(--border);
      box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    }

    /* Header */
    .header {
      border-bottom: 1px solid var(--border);
      margin-bottom: 24px;
      padding-bottom: 16px;
    }

    .title {
      font-size: 28px;
      margin: 0;
    }

    .meta {
      color: var(--muted);
      font-size: 14px;
    }

    /* Markdown Content Styling */
    #content h1, #content h2, #content h3 {
      margin-top: 24px;
    }

    #content h1 {
      border-bottom: 1px solid var(--border);
      padding-bottom: 6px;
    }

    #content p {
      line-height: 1.7;
    }

    #content pre {
      background: #0d1117;
      color: #c9d1d9;
      padding: 16px;
      border-radius: 8px;
      overflow-x: auto;
    }

    #content code {
      background: #eaeef2;
      padding: 2px 6px;
      border-radius: 6px;
    }

    #content blockquote {
      border-left: 4px solid var(--accent);
      padding-left: 12px;
      color: var(--muted);
      margin: 16px 0;
    }

    .mermaid {
      text-align: center;
      margin: 30px 0;
    }

    .footer {
      border-top: 1px solid var(--border);
      margin-top: 40px;
      padding-top: 16px;
      font-size: 13px;
      color: var(--muted);
      text-align: center;
    }
  </style>
</head>
<body>

  <div class="page">
    <div class="report">

      <!-- Header -->
      <div class="header">
        <h1 class="title">AI Health Assistant Report</h1>
        <div class="meta">Generated on April 2026 • Hackathon Project</div>
      </div>

      <!-- Markdown Rendered Content -->
      <div id="content"></div>

      <div class="footer">
        © 2026 Project Report • Built with Markdown + Mermaid
      </div>

    </div>
  </div>

  <script>
    mermaid.initialize({ startOnLoad: false });

    // 🔥 Real-life markdown input (this would come from backend/file)
    const markdown = `
## 📌 Overview
This project predicts diseases based on symptoms using AI.

## ⚙️ Workflow

\`\`\`mermaid
graph TD
  A[User Input Symptoms] --> B[AI Model]
  B --> C[Prediction]
  C --> D[Report Generated]
\`\`\`

## 🚀 Features
- Symptom-based prediction
- Report analysis
- Voice input support

## 💡 Sample Code
\`\`\`js
function predict() {
  return "Disease Result";
}
\`\`\`

> This system improves early diagnosis accuracy.
`;

    function render() {
      let raw = markdown;

      // Convert mermaid blocks
      raw = raw.replace(/```mermaid([\\s\\S]*?)```/g, (_, code) => {
        return `<div class="mermaid">${code}</div>`;
      });

      // Convert markdown → HTML
      const html = marked.parse(raw);
      document.getElementById("content").innerHTML = html;

      // Render diagrams
      mermaid.init(undefined, document.querySelectorAll(".mermaid"));
    }

    render();
  </script>

</body>
</html>
